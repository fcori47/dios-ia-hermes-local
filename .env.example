# =============================================================================
# Hermes Agent + Ollama — configuración
# Copiar este archivo a .env y editar lo que haga falta:
#     cp .env.example .env          (Windows: Copy-Item .env.example .env)
# =============================================================================

# -----------------------------------------------------------------------------
# EL MODELO  👇  esto es lo único que la mayoría va a querer tocar
# -----------------------------------------------------------------------------
# Cualquier modelo de https://ollama.com/library
#   qwen3:4b    ~2.6GB  el más liviano, ideal para 8 GB de RAM
#   qwen3:8b    ~5GB    liviano, va cómodo con 16 GB                (default)
#   qwen3:14b   ~9GB    mejor calidad, pide una GPU/PC decente
#   qwen3:30b   ~19GB   muy capaz, pesado (mucha RAM/VRAM)
#   hermes3     ~4.7GB  modelo Hermes de Nous Research
#   llama3.1:8b ~4.9GB  alternativa popular
OLLAMA_MODEL=qwen3:8b

# -----------------------------------------------------------------------------
# Conexión Hermes -> Ollama  (editar a mano según tu sistema; ver README)
# -----------------------------------------------------------------------------
# Endpoint OpenAI-compatible de Ollama. Esta es la MISMA URL que vas a pegar en
# "hermes model" -> "Custom endpoint" en el Paso 3:
#   Ollama en Docker (Windows/Linux):  http://ollama:11434/v1            (default)
#   Ollama nativo en el host (macOS):  http://host.docker.internal:11434/v1
OPENAI_BASE_URL=http://ollama:11434/v1

# API key dummy: Ollama no la valida. Cambiar solo si apuntás a un endpoint real.
OPENAI_API_KEY=ollama

# -----------------------------------------------------------------------------
# Ollama (modo "bundled" — Ollama dentro de Docker)
# -----------------------------------------------------------------------------
# Puerto de Ollama expuesto al host (solo 127.0.0.1). Solo tiene efecto si
# DESCOMENTÁS el bloque "ports:" del servicio ollama en docker-compose.yml
# (por defecto está comentado porque Hermes le pega por la red interna de Docker).
OLLAMA_HOST_PORT=11434

# Cuánto mantiene Ollama el modelo cargado en memoria entre requests.
OLLAMA_KEEP_ALIVE=24h

# Requests de inferencia en paralelo (1 alcanza con 1 GPU).
OLLAMA_NUM_PARALLEL=1

# Máximo de modelos cargados a la vez.
OLLAMA_MAX_LOADED_MODELS=1

# Contexto que Ollama le sirve al modelo. Hermes necesita más que el default de
# Ollama (4096, que le queda chico). No se puede setear por la API, por eso va
# acá (lo toma el servidor Ollama).
#   ⚠️ Más contexto = más RAM. 32768 entra holgado en el contexto nativo de
#   qwen3 (~40960 es su techo; pedir más no suma contexto, solo gasta RAM).
#   En una máquina de 8 GB puede ser mucho: si el modelo se cuelga o no carga,
#   bajalo (ej. 8192 o 16384) o usá un modelo más chico (qwen3:4b). Ver README.
OLLAMA_CONTEXT_LENGTH=32768

# -----------------------------------------------------------------------------
# Hermes (portal OPCIONAL)
# -----------------------------------------------------------------------------
# El flujo por defecto es 100% local y NO usa esto. Solo si elegís usar el
# portal de Nous (opcional, requiere cuenta: "hermes setup --portal") hace falta
# un puerto para el callback OAuth. En ese caso descomentá la línea de abajo y
# las líneas "ports:" del servicio hermes en docker-compose.yml.
# HERMES_OAUTH_PORT=8080

# -----------------------------------------------------------------------------
# Workspace (OPCIONAL) — carpeta del host montada en /workspace
# -----------------------------------------------------------------------------
# Descomentar acá y también la línea del volumen bajo `hermes` en
# docker-compose.yml para darle a Hermes acceso a archivos de tu PC.
# Ruta absoluta o relativa a este archivo.
#
# WORKSPACE_PATH=./workspace
# WORKSPACE_PATH=C:/Users/tu-usuario/proyectos/mi-proyecto   # Windows
# WORKSPACE_PATH=/Users/tu-usuario/proyectos/mi-proyecto     # macOS

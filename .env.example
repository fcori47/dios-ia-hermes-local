# =============================================================================
# Hermes Agent + Ollama — configuración
# Copiar este archivo a .env y editar lo que haga falta:
#     cp .env.example .env
# (los scripts start.sh / start.ps1 lo crean solos si no existe)
# =============================================================================

# -----------------------------------------------------------------------------
# EL MODELO  👇  esto es lo único que la mayoría va a querer tocar
# -----------------------------------------------------------------------------
# Cualquier modelo de https://ollama.com/library
#   qwen3:8b    ~5GB    liviano, corre en casi cualquier PC        (default)
#   qwen3:14b   ~9GB    mejor calidad, pide una GPU/PC decente
#   qwen3:30b   ~19GB   muy capaz, pesado (mucha RAM/VRAM)
#   hermes3     ~4.7GB  modelo Hermes de Nous Research
#   llama3.1:8b ~4.9GB  alternativa popular
OLLAMA_MODEL=qwen3:8b

# -----------------------------------------------------------------------------
# Conexión Hermes -> Ollama  (los scripts setean esto automáticamente)
# -----------------------------------------------------------------------------
# Endpoint OpenAI-compatible de Ollama:
#   Ollama en Docker (Windows/Linux):  http://ollama:11434/v1            (default)
#   Ollama nativo en el host (macOS):  http://host.docker.internal:11434/v1
OPENAI_BASE_URL=http://ollama:11434/v1

# API key dummy: Ollama no la valida. Cambiar solo si apuntás a un endpoint real.
OPENAI_API_KEY=ollama

# -----------------------------------------------------------------------------
# Ollama (modo "bundled" — Ollama dentro de Docker)
# -----------------------------------------------------------------------------
# Puerto de Ollama expuesto al host (solo 127.0.0.1).
OLLAMA_HOST_PORT=11434

# Cuánto mantiene Ollama el modelo cargado en memoria entre requests.
OLLAMA_KEEP_ALIVE=24h

# Requests de inferencia en paralelo (1 alcanza con 1 GPU).
OLLAMA_NUM_PARALLEL=1

# Máximo de modelos cargados a la vez.
OLLAMA_MAX_LOADED_MODELS=1

# -----------------------------------------------------------------------------
# Hermes
# -----------------------------------------------------------------------------
# Puerto del callback OAuth de `hermes setup --portal`.
# Tras autorizar, el browser del host vuelve a http://localhost:8080
HERMES_OAUTH_PORT=8080

# -----------------------------------------------------------------------------
# Workspace (OPCIONAL) — carpeta del host montada en /workspace
# -----------------------------------------------------------------------------
# Descomentar acá y también la línea del volumen bajo `hermes` en
# docker-compose.yml para darle a Hermes acceso a archivos de tu PC.
# Ruta absoluta o relativa a este archivo.
#
# WORKSPACE_PATH=./workspace
# WORKSPACE_PATH=C:/Users/tu-usuario/proyectos/mi-proyecto   # Windows
# WORKSPACE_PATH=/Users/tu-usuario/proyectos/mi-proyecto     # macOS
